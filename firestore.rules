rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'ADMIN';
    }
    
    function isAgent() {
      return isSignedIn() && getUserData().role == 'AGENT';
    }
    
    function isApproved() {
      return getUserData().isApproved == true;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }
    
    // Agent Profiles
    match /agentProfiles/{profileId} {
      allow read: if true; // Publicly viewable
      allow write: if isAdmin() || (isAgent() && request.auth.uid == resource.data.userId);
      allow create: if isAgent() && request.auth.uid == request.resource.data.userId;
    }
    
    // Listings collection
    match /listings/{listingId} {
      allow read: if true; // Everyone can browse
      allow create: if isAgent() && isApproved() && request.resource.data.agentId == request.auth.uid;
      allow update, delete: if isAdmin() || (isAgent() && resource.data.agentId == request.auth.uid);
    }
    
    // Bookings collection
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.agentId || 
        request.auth.uid == resource.data.consumerId ||
        isAdmin()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.agentId || 
        request.auth.uid == resource.data.consumerId ||
        isAdmin()
      );
    }
    
    // Subscriptions
    match /subscriptions/{subId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.agentId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
